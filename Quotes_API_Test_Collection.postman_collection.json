    {
      "name": "PHASE 2: TEST YOUR API (Examples)",
      "description": "Use these as templates for testing. Create, update, and delete as needed. But remember to restore!",
      "item": [
        {
          "name": "Example: GET Quote by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://docker-inf653-midterm-example.onrender.com/api/quotes/?id=1",
              "protocol": "https",
              "host": [
                "docker-inf653-midterm-example",
                "onrender",
                "com"
              ],
              "path": [
                "api",
                "quotes",
                ""
              ],
              "query": [
                {
                  "key": "id",
                  "value": "1"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Example: GET Quotes by Author",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://docker-inf653-midterm-example.onrender.com/api/quotes/?author_id=1",
              "protocol": "https",
              "host": [
                "docker-inf653-midterm-example",
                "onrender",
                "com"
              ],
              "path": [
                "api",
                "quotes",
                ""
              ],
              "query": [
                {
                  "key": "author_id",
                  "value": "1"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Example: GET Random Quote",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "https://docker-inf653-midterm-example.onrender.com/api/quotes/?random=true",
              "protocol": "https",
              "host": [
                "docker-inf653-midterm-example",
                "onrender",
                "com"
              ],
              "path": [
                "api",
                "quotes",
                ""
              ],
              "query": [
                {
                  "key": "random",
                  "value": "true"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Example: POST New Quote (REMEMBER TO DELETE!)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quote\": \"This is a test quote\",\n  \"author_id\": 1,\n  \"category_id\": 1\n}"
            },
            "url": {
              "raw": "https://docker-inf653-midterm-example.onrender.com/api/quotes/",
              "protocol": "https",
              "host": [
                "docker-inf653-midterm-example",
                "onrender",
                "com"
              ],
              "path": [
                "api",
                "quotes",
                ""
              ]
            },
            "description": "Creates a new quote. NOTE THE ID in the response. You MUST DELETE this later!"
          },
          "response": []
        },
        {
          "name": "Example: PUT Update Quote (REMEMBER TO RESTORE!)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 1,\n  \"quote\": \"Updated quote text\",\n  \"author_id\": 1,\n  \"category_id\": 1\n}"
            },
            "url": {
              "raw": "https://docker-inf653-midterm-example.onrender.com/api/quotes/",
              "protocol": "https",
              "host": [
                "docker-inf653-midterm-example",
                "onrender",
                "com"
              ],
              "path": [
                "api",
                "quotes",
                ""
              ]
            },
            "description": "Updates a quote. Make sure you know the original text so you can restore it!"
          },
          "response": []
        },
        {
          "name": "Example: DELETE Quote (ONLY delete what you created!)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 26\n}"
            },
            "url": {
              "raw": "https://docker-inf653-midterm-example.onrender.com/api/quotes/",
              "protocol": "https",
              "host": [
                "docker-inf653-midterm-example",
                "onrender",
                "com"
              ],
              "path": [
                "api",
                "quotes",
                ""
              ]
            },
            "description": "Deletes a quote. Only use this ID from the POST you just made!"
          },
          "response": []
        }
      ]
